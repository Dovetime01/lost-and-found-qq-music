# Next.js build output — regenerated by pnpm build
.next/
out/
*.tsbuildinfo
next-env.d.ts

# Tests and logs
coverage/
*.log
pnpm-debug.log*

# Secrets — configure the same keys on Vercel Env Vars instead
.env
.env*.local
!.env.local.example

# Vercel CLI local link/cache
.vercel/

# OS and editor files
.DS_Store
Thumbs.db
