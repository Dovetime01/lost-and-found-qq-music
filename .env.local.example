# Final demo API configuration.
# Copy this file to .env.local and fill in your private values.
# Do not commit .env.local or share screenshots containing keys.

# 1) Ticket extraction: Baidu accurate OCR followed by Doubao Ark structured extraction.
BAIDU_OCR_API_KEY=replace_with_your_baidu_api_key
BAIDU_OCR_SECRET_KEY=replace_with_your_baidu_secret_key
TICKET_ARK_API_KEY=replace_with_your_ark_api_key
TICKET_ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
TICKET_ARK_MODEL=doubao-seed-2-0-mini-260428

# 2) Vision API: image/video frame evidence analysis only.
VISION_API_KEY=replace_with_your_private_key
VISION_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VISION_MODEL=replace_with_your_vision_model_or_endpoint_id

# 3) LLM API: lyrics, user feelings, emotional themes, lost item copy.
LLM_API_KEY=replace_with_your_private_key
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_MODEL=replace_with_your_llm_model_or_endpoint_id

# Legacy generic names still work as a fallback for both Vision and LLM.
AI_API_KEY=replace_with_your_private_key
AI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
AI_MODEL=replace_with_your_model_or_endpoint_id

# Multimodal emotion-claim via Ark Responses API (Seed 2.0 Lite).
# Falls back to VISION_*, then LLM_*, then AI_* only if these are unset.
MULTIMODAL_API_KEY=replace_with_your_private_key
MULTIMODAL_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
MULTIMODAL_MODEL=doubao-seed-2-0-lite-260428

# When these values are set, /api/analyze-memory can ask the LLM to generate:
# - lost item profile
# - emotion tags
# - narrative copy
# - music search keywords across any artist

# Equivalent provider-specific names also work:
# ARK_API_KEY=replace_with_your_private_key
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_MODEL=replace_with_your_model_or_endpoint_id

# 4) QQ Music API adapter.
# AppKey is only read on the server. Never expose it in client-side code or screenshots.
QQ_MUSIC_APP_ID=replace_with_your_qq_music_app_id
QQ_MUSIC_APP_KEY=replace_with_your_qq_music_app_key
QQ_MUSIC_BASE_URL=https://qplaycloud.y.qq.com/rpc_proxy/fcgi-bin/music_open_api.fcg

# Optional QQ Music login/device parameters.
# Fill these only if your OpenAPI permission package requires a user/device login state.
# QQ_MUSIC_OPEN_APP_ID=replace_with_qqmusic_open_appid
# QQ_MUSIC_OPEN_ID=replace_with_qqmusic_open_id
# QQ_MUSIC_ACCESS_TOKEN=replace_with_qqmusic_access_token
# QQ_MUSIC_DEVICE_ID=lost-found-demo-device
# QQ_MUSIC_CLIENT_IP=replace_with_client_ip
# QQ_MUSIC_LOGIN_TYPE=6
# Used by /qq-login QR auth. Prefer the package name submitted when applying the app.
# QQ_MUSIC_PACKAGE_NAME=lost-and-found-share
# QQ_MUSIC_DEV_NAME=LostFoundDemo

# 5) ACRCloud live music recognition. Server-only.
# Uses ACRCloud HTTP Identify API (data_type=audio) from Node — no Python needed.
# On Vercel, set these three (+ optional PROTOCOL). Do NOT set a Windows python path.
ACRCLOUD_HOST=identify-cn-north-1.acrcloud.cn
ACRCLOUD_ACCESS_KEY=replace_with_your_acrcloud_access_key
ACRCLOUD_ACCESS_SECRET=replace_with_your_acrcloud_access_secret
ACRCLOUD_PROTOCOL=http

# Legacy Xunfei humming recognition fallback (not used by the video pipeline).
XFYUN_SONG_APP_ID=replace_with_your_xfyun_app_id
XFYUN_SONG_API_KEY=replace_with_your_xfyun_api_key

# Optional dedicated text models for claim/radio copy; LLM_* and AI_* are fallbacks.
# CLAIM_API_KEY=replace_with_your_private_key
# CLAIM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# CLAIM_MODEL=doubao-seed-2-0-mini-260428
# RADIO_API_KEY=replace_with_your_private_key
# RADIO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# RADIO_MODEL=doubao-seed-2-0-mini-260428

# 6) MVP4D Supabase public wall configuration.
# These are used later for real public wall posting and listing.
SUPABASE_URL=replace_with_your_supabase_project_url
SUPABASE_ANON_KEY=replace_with_your_supabase_anon_key
